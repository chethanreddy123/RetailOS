DATABASE_URL=postgres://user:password@ep-xxx.us-east-2.aws.neon.tech/neondb?sslmode=require
JWT_SECRET=change-me-to-a-long-random-secret
PORT=8080

# "dev" or "development" = uses SMTP, anything else (or unset) = uses Resend API
ENVIRONMENT=dev

# Resend (production only — used when ENVIRONMENT is not dev/development)
RESEND_API_KEY=re_xxxxxxxxxxxx
RESEND_FROM=RetailOS <noreply@yourdomain.com>

# SMTP (local dev only — used when ENVIRONMENT=dev or ENVIRONMENT=development)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_USERNAME=retailos.noreply@gmail.com
SMTP_PASSWORD=your-gmail-app-password
SMTP_FROM=RetailOS <retailos.noreply@gmail.com>
